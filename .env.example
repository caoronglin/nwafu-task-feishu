# ======================
# 飞书应用配置
# ======================
# 在飞书开放平台创建企业自建应用后获取
# https://open.feishu.cn/

FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_USER_OPEN_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

